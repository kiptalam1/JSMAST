@baseUrl=http://localhost:3000

### Fetch all posts
GET {{baseUrl}}/posts

### one post
GET {{baseUrl}}/posts/1

### create post 
# @kulala-jq .
POST {{baseUrl}}/posts/create
Content-Type: application/json

{
    "title": "first post with db",
     "content": "first db post",
   "authorName": "adams"
}

### update post
PUT {{baseUrl}}/posts/1
Content-Type: application/json

{
    "title": "first edited",
    "content": "edited",
    "authorName": "smada"
}

### Delete post;
DELETE {{baseUrl}}/posts/1
